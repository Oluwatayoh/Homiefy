
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account within the KINETY system, associated with a Google OAuth identity and family role.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity (Firebase UID)."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user.",
          "format": "email"
        },
        "name": {
          "type": "string",
          "description": "Display name of the user."
        },
        "photoUrl": {
          "type": "string",
          "description": "Profile photo URL or Base64 string."
        },
        "familyId": {
          "type": "string",
          "description": "ID of the family the user belongs to."
        },
        "role": {
          "type": "string",
          "enum": ["Admin", "Co-Manager", "Member", "Child"],
          "description": "Role within the family."
        },
        "preferences": {
          "type": "object",
          "properties": {
            "currency": { "type": "string" },
            "alertThreshold": { "type": "number" },
            "pushNotifications": { "type": "boolean" }
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "lastLogin": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "email", "name", "role", "createdAt", "lastLogin"]
    },
    "Family": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Family",
      "type": "object",
      "description": "Represents a family unit.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "inviteCode": { "type": "string" },
        "inviteCodeExpires": { "type": "string", "format": "date-time" },
        "currency": { "type": "string" },
        "approvalThresholds": {
          "type": "object",
          "properties": {
            "Member": { "type": "number" },
            "Co-Manager": { "type": "number" }
          }
        },
        "members": {
          "type": "object",
          "description": "Map of userId to role for fast lookups."
        },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "inviteCode", "currency", "members", "createdBy", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/families/{familyId}",
        "definition": {
          "entityName": "Family",
          "schema": { "$ref": "#/backend/entities/Family" },
          "description": "Family data."
        }
      }
    ]
  }
}
