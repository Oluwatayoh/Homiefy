
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account within the KINETY system.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "photoUrl": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "familyId": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Co-Manager", "Member", "Child"] },
        "preferences": {
          "type": "object",
          "properties": {
            "currency": { "type": "string" },
            "alertThreshold": { "type": "number" },
            "pushNotifications": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "name", "role", "createdAt", "lastLogin"]
    },
    "Family": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Family",
      "type": "object",
      "description": "Represents a family unit.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "inviteCode": { "type": "string" },
        "inviteCodeExpires": { "type": "string", "format": "date-time" },
        "currency": { "type": "string" },
        "approvalThresholds": {
          "type": "object",
          "properties": {
            "Member": { "type": "number" },
            "Co-Manager": { "type": "number" }
          }
        },
        "members": { "type": "object" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "inviteCode", "currency", "members", "createdBy", "createdAt"]
    },
    "Budget": {
      "title": "Budget",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Usually YYYY-MM format" },
        "totalIncome": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Closed"] },
        "envelopes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "icon": { "type": "string" },
              "allocated": { "type": "number" },
              "spent": { "type": "number" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "description": "A financial transaction logged by a user.",
      "properties": {
        "id": { "type": "string" },
        "familyId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "receiptPhoto": { "type": "string", "description": "Base64 encoded photo" },
        "sentiment": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["familyId", "userId", "amount", "category", "date", "createdAt"]
    },
    "Decision": {
      "title": "Decision",
      "type": "object",
      "description": "An AI-powered pre-spending decision check.",
      "properties": {
        "id": { "type": "string" },
        "familyId": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["Need", "Want", "Luxury"] },
        "aiAnalysis": {
          "type": "object",
          "properties": {
            "impactSummary": { "type": "string" },
            "regretScore": { "type": "number" },
            "recommendation": { "type": "string" },
            "recommendationType": { "type": "string", "enum": ["Proceed Confidently", "Consider Carefully", "Reconsider", "Seek Approval"] }
          }
        },
        "userAction": { "type": "string", "enum": ["proceeded", "canceled", "pending"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Approval": {
      "title": "Approval",
      "type": "object",
      "description": "A request for spending approval.",
      "properties": {
        "id": { "type": "string" },
        "familyId": { "type": "string" },
        "requesterId": { "type": "string" },
        "requesterName": { "type": "string" },
        "approverId": { "type": "string" },
        "transactionData": { "type": "object" },
        "justification": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Denied"] },
        "approverReason": { "type": "string" },
        "approvedAmount": { "type": "number" },
        "requestedAt": { "type": "string", "format": "date-time" },
        "resolvedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["familyId", "requesterId", "transactionData", "status", "requestedAt"]
    },
    "Goal": {
      "title": "Goal",
      "type": "object",
      "description": "A family financial goal.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string", "format": "date-time" },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "targetAmount", "currentAmount", "deadline"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/families/{familyId}",
        "definition": {
          "entityName": "Family",
          "schema": { "$ref": "#/backend/entities/Family" },
          "description": "Family data."
        }
      },
      {
        "path": "/families/{familyId}/budgets/{budgetId}",
        "definition": {
          "entityName": "Budget",
          "schema": { "$ref": "#/backend/entities/Budget" },
          "description": "Monthly family budgets."
        }
      },
      {
        "path": "/families/{familyId}/transactions/{transactionId}",
        "definition": {
          "entityName": "Transaction",
          "schema": { "$ref": "#/backend/entities/Transaction" },
          "description": "Family transactions."
        }
      },
      {
        "path": "/families/{familyId}/decisions/{decisionId}",
        "definition": {
          "entityName": "Decision",
          "schema": { "$ref": "#/backend/entities/Decision" },
          "description": "Spending decisions."
        }
      },
      {
        "path": "/families/{familyId}/approvals/{approvalId}",
        "definition": {
          "entityName": "Approval",
          "schema": { "$ref": "#/backend/entities/Approval" },
          "description": "Spending approval requests."
        }
      },
      {
        "path": "/families/{familyId}/goals/{goalId}",
        "definition": {
          "entityName": "Goal",
          "schema": { "$ref": "#/backend/entities/Goal" },
          "description": "Family financial goals."
        }
      }
    ]
  }
}
