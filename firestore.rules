rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Homiefy SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * 1. Path-based isolation for User Profiles.
     * 2. Denormalized membership for all family data to satisfy "Rules are not filters".
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // High-performance check for list operations using denormalized membership map.
    function hasMembership(data) {
      return isSignedIn() && data.members[request.auth.uid] != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for individual user profiles.
     */
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    /**
     * @description Rules for family units and their shared data.
     */
    match /families/{familyId} {
      // Allow signed-in users to get and list families (for joining)
      allow get, list: if isSignedIn();
      
      // Creation and updates based on membership/admin roles.
      allow create: if isSignedIn();
      allow update: if hasMembership(resource.data);
      allow delete: if isSignedIn() && resource.data.members[request.auth.uid] == 'Admin';

      /**
       * @description Rules for family sub-data (Budgets, Goals, Transactions, Approvals, Decisions).
       * Every document MUST contain a 'members' map for this high-performance check.
       */
      match /{allSubcollections=**} {
        allow read, write: if hasMembership(resource.data) || hasMembership(request.resource.data);
      }
    }
  }
}