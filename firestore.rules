rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Homiefy SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * 1. Path-based isolation for User Profiles.
     * 2. Membership-based isolation for Family data.
     * 3. Rules require explicit query filters for list operations.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the user is a member of a family document by looking up the document's members map.
    function isMemberOfFamily(familyId) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/families/$(familyId)).data.members[request.auth.uid] != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for individual user profiles.
     */
    match /userProfiles/{userId} {
      allow get, list: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Rules for family units and their shared data.
     */
    match /families/{familyId} {
      // Allow any signed-in user to 'get' families (necessary for joining via ID)
      // Allow 'list' only for joining via invite code search
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      // Only the creator can create the family.
      allow create: if isSignedIn() && request.resource.data.adminUserId == request.auth.uid;
      
      // Updates and deletes are restricted to members or admins.
      allow update: if isMemberOfFamily(familyId);
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/families/$(familyId)).data.members[request.auth.uid] == 'Admin';

      /**
       * @description Rules for family sub-data.
       * We use explicit matches for better clarity and performance in list operations.
       */
      
      // Approvals, Transactions, Goals, Budgets, Decisions
      match /{subCollection}/{docId} {
        // For list operations, the query must be filtered by the user's membership.
        // We allow list if the document's own members map contains the user, or if they are a family member.
        allow list: if isSignedIn() && (
          resource.data.members[request.auth.uid] != null ||
          isMemberOfFamily(familyId)
        );
        
        // Single document access and mutations require family membership.
        allow get, create, update, delete: if isMemberOfFamily(familyId);
      }
    }
  }
}