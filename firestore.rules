rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * KINETY SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * 1. Path-based isolation for User Profiles.
     * 2. Parent-document membership check for family sub-data.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // High-performance check for family membership by checking the parent Family document.
    function isFamilyMember(familyId) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/families/$(familyId)) &&
        get(/databases/$(database)/documents/families/$(familyId)).data.members[request.auth.uid] != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for individual user profiles.
     */
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    /**
     * @description Rules for family units and their shared data.
     */
    match /families/{familyId} {
      // Allow signed-in users to get a family (necessary for joining)
      allow get: if isSignedIn();
      // Allow listing families for the joining process
      allow list: if isSignedIn();
      
      // Creation and updates based on membership.
      allow create: if isSignedIn();
      allow update: if isFamilyMember(familyId);
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/families/$(familyId)).data.members[request.auth.uid] == 'Admin';

      /**
       * @description Rules for family sub-data.
       * These rely on the isFamilyMember helper which checks the parent document.
       * For 'list' operations to succeed, the query must be restricted to the family path.
       */
      match /{allSubcollections=**} {
        allow read, write: if isFamilyMember(familyId);
      }
    }
  }
}