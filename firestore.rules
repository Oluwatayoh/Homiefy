rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Homiefy SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * 1. Path-based isolation for User Profiles.
     * 2. Membership-based isolation for Family data.
     * 3. Rules are kept simple to avoid hidden index requirements or 'Missing Permissions' crashes.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the user is a member of a family document by looking up the document's members map.
    function isMemberOfFamily(familyId) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/families/$(familyId)).data.members[request.auth.uid] != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for individual user profiles.
     */
    match /userProfiles/{userId} {
      allow get, list: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Rules for family units and their shared data.
     */
    match /families/{familyId} {
      // Allow any signed-in user to 'get' or 'list' families (necessary for joining via code).
      allow get, list: if isSignedIn();
      
      // Only the creator can create the family.
      allow create: if isSignedIn() && request.resource.data.adminUserId == request.auth.uid;
      
      // Updates and deletes are restricted to members or admins.
      allow update: if isMemberOfFamily(familyId);
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/families/$(familyId)).data.members[request.auth.uid] == 'Admin';

      /**
       * @description Recursive match for all family subcollections (Budgets, Goals, Transactions, Approvals, Decisions).
       * Access is granted if the user is a member of the family.
       */
      match /{allSubcollections=**} {
        // For list operations, the query must also include a filter that matches this logic if it's data-bound.
        // However, since we're using path-based parent checks, simple subcollection queries are allowed for members.
        allow get, list: if isMemberOfFamily(familyId);
        allow create, update, delete: if isMemberOfFamily(familyId);
      }
    }
  }
}