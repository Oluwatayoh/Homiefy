rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Homiefy SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * 1. Path-based isolation for User Profiles.
     * 2. Parent-based membership isolation for Family data.
     * 3. Simplified listing rules to avoid complex query/filter mismatches.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the user is a member of a family document by looking up the document's members map.
    function isMemberOfFamily(familyId) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/families/$(familyId)).data.members[request.auth.uid] != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for individual user profiles.
     */
    match /userProfiles/{userId} {
      allow get, list: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Rules for family units and their shared data.
     */
    match /families/{familyId} {
      // Allow signed-in users to get and list families (critical for joining via invite code)
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      // Only the creator can create the family.
      allow create: if isSignedIn() && request.resource.data.adminUserId == request.auth.uid;
      
      // Updates and deletes are restricted to members or admins.
      allow update: if isMemberOfFamily(familyId);
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/families/$(familyId)).data.members[request.auth.uid] == 'Admin';

      /**
       * @description Rules for family sub-data (Budgets, Goals, Transactions, Approvals, Decisions).
       * We use a parent-check for consistent access control across all family data.
       */
      match /{allSubcollections=**} {
        allow list, get, create, update, delete: if isMemberOfFamily(familyId);
      }
    }
  }
}