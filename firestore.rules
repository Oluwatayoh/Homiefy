rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Homiefy SECURITY RULES - ROBUST PROTOTYPING MODE
     *
     * CORE PHILOSOPHY:
     * This ruleset balances security with rapid iteration. It uses parent-document 
     * validation for subcollections to simplify queries and avoid complex composite index 
     * requirements while maintaining strict data isolation between families.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if a user is a member of a specific family document.
    function isFamilyMember(data) {
      return isSignedIn() && data != null && data.members != null && data.members[request.auth.uid] != null;
    }

    // Checks if the user has the 'Admin' role in the family data.
    function isFamilyAdmin(data) {
      return isSignedIn() && data != null && data.members != null && data.members[request.auth.uid] == 'Admin';
    }

    // Checks membership by looking up the parent family document.
    function isMemberOfFamily(familyId) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/families/$(familyId)).data.members[request.auth.uid] != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for individual user profiles.
     */
    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Rules for family units.
     */
    match /families/{familyId} {
      // Allow 'get' if document exists and user is member, or if they are signed in (for joining).
      allow get: if isSignedIn();
      // Allow 'list' for searching (e.g., invite codes) and for members.
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && request.resource.data.adminUserId == request.auth.uid;
      allow update: if isFamilyMember(resource.data) || isFamilyAdmin(resource.data);
      allow delete: if isFamilyAdmin(resource.data);

      /**
       * @description Shared subcollections (Budgets, Goals, Transactions, Approvals, Decisions).
       * Access is granted if the user is a member of the parent family document.
       */
      match /{subcollection}/{id} {
        allow get, list: if isMemberOfFamily(familyId);
        allow create: if isMemberOfFamily(familyId);
        allow update: if isMemberOfFamily(familyId);
        allow delete: if isMemberOfFamily(familyId);
      }
    }
  }
}