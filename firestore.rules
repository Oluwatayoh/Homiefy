rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Homiefy SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * 1. Path-based isolation for User Profiles.
     * 2. Path-based parent authorization for family sub-data.
     * This ensures high-performance list operations without complex inequality filters.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // High-performance check for family membership by checking the parent Family document.
    function isFamilyMember(familyId) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/families/$(familyId)) &&
        get(/databases/$(database)/documents/families/$(familyId)).data.members[request.auth.uid] != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for individual user profiles.
     */
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    /**
     * @description Rules for family units and their shared data.
     */
    match /families/{familyId} {
      // Allow signed-in users to get and list families (necessary for joining)
      allow get, list: if isSignedIn();
      
      // Creation and updates based on membership/admin roles.
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.members[request.auth.uid] != null;
      allow delete: if isSignedIn() && resource.data.members[request.auth.uid] == 'Admin';

      /**
       * @description Rules for family sub-data (Budgets, Goals, Transactions, Approvals, Decisions).
       * These rely on the isFamilyMember helper which checks the parent document.
       */
      match /{allSubcollections=**} {
        allow read, write: if isFamilyMember(familyId);
      }
    }
  }
}