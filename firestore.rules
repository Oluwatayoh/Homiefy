rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HOMIEFY SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * 1. Path-based isolation for User Profiles.
     * 2. Family membership is the gatekeeper for all shared household data.
     * 3. Membership is stored as a map on the Family document: members: { uid: role }
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the user is a member of the family.
    // We look up the family document and check the members map.
    function isFamilyMember(familyId) {
      let family = get(/databases/$(database)/documents/families/$(familyId));
      return isSignedIn() && family != null && family.data.members[request.auth.uid] != null;
    }

    // Checks if the requester and the target resource share the same familyId.
    function areInSameFamily(resourceFamilyId) {
      let myProfile = get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
      return isSignedIn() && resourceFamilyId != null && myProfile.familyId == resourceFamilyId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for individual user profiles.
     */
    match /userProfiles/{userId} {
      // Allow reading if owner OR if they are in the same family (to see names/avatars).
      // This is critical for the Family page to list members.
      allow read: if isOwner(userId) || (isSignedIn() && areInSameFamily(resource.data.familyId));
      allow write: if isOwner(userId);
    }

    /**
     * @description Rules for family units and their shared data.
     */
    match /families/{familyId} {
      // Basic family access.
      allow get: if isSignedIn();
      
      // Only members can list families they belong to.
      allow list: if isSignedIn() && isFamilyMember(familyId);
      
      // Creation.
      allow create: if isSignedIn();
      
      // Update logic:
      // 1. Existing members can update (Admin/Lead roles usually handled by app logic).
      // 2. New members can join by adding their own UID to the members map.
      allow update: if isSignedIn() && (
        isFamilyMember(familyId) || 
        (
          // Case: Joining a family. 
          // They are adding their own UID to the members map.
          request.resource.data.members[request.auth.uid] != null &&
          request.resource.data.inviteCode == resource.data.inviteCode
        )
      );

      // Only admins can delete the family record.
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/families/$(familyId)).data.members[request.auth.uid] == 'Admin';

      /**
       * @description Explicit rules for family sub-data.
       * Subcollections in Firestore do not inherit permissions from parents.
       */
      match /transactions/{id} { allow read, write: if isFamilyMember(familyId); }
      match /budgets/{id} { allow read, write: if isFamilyMember(familyId); }
      match /goals/{id} { allow read, write: if isFamilyMember(familyId); }
      match /approvals/{id} { allow read, write: if isFamilyMember(familyId); }
      match /decisions/{id} { allow read, write: if isFamilyMember(familyId); }
      
      // Catch-all for any other nested subcollections
      match /{allSubcollections=**} {
        allow read, write: if isFamilyMember(familyId);
      }
    }
  }
}