rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Homiefy SECURITY RULES - PROTOTYPING MODE
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a strict, high-security authorization model while remaining flexible 
     * regarding the specific data schema to support rapid iteration. It prioritizes 
     * "Authorization Independence," meaning rules are designed to be evaluated without 
     * expensive cross-document lookups (get() calls).
     *
     * DATA STRUCTURE & ACCESS MODEL:
     * 1. Private User Data: Located at /userProfiles/{userId}. Access is restricted to 
     *    the authenticated user whose UID matches the document ID.
     * 2. Collaborative Family Data: Located at /families/{familyId} and its subcollections. 
     *    Access is governed by a denormalized 'members' map (UID to Role) present on every 
     *    document within this branch.
     *
     * KEY SECURITY DECISIONS:
     * - No Public Access: All read and write operations require authentication.
     * - Denormalization for Performance: Family membership data is copied onto all child 
     *   records (budgets, goals, transactions). This allows for atomic security checks 
     *   without hitting Firestore read limits for security overhead.
     * - Relational Integrity: On creation, documents must correctly reference the 
     *   authenticated user's identity to prevent data spoofing.
     * - Resource-Specific Roles: Permissions within families (Admin, Parent, Child) 
     *   are checked directly against the 'members' map on the document.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Used for update/delete to ensure document existence and ownership.
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // Checks if the user is present in the denormalized 'members' map.
    function isFamilyMember(data) {
      return isSignedIn() && data.members != null && data.members[request.auth.uid] != null;
    }

    // Checks if the user has the 'Admin' role in the family.
    function isFamilyAdmin(data) {
      return isSignedIn() && data.members != null && data.members[request.auth.uid] == 'Admin';
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for individual user profiles.
     * @path /userProfiles/{userId}
     * @allow (create) if the user is authenticated and the path UID matches their UID.
     * @deny (list) if the user tries to list all profiles.
     * @principle Path-based ownership and self-creation validation.
     */
    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for family units. Access is controlled by the 'members' map.
     * @path /families/{familyId}
     * @allow (create) if the user is signed in and sets themselves as the admin.
     * @deny (update) if the user is not a member or doesn't have an admin role.
     * @principle Shared access via membership map and role-based write control.
     */
    match /families/{familyId} {
      allow get: if isFamilyMember(resource.data);
      allow list: if isSignedIn() && resource.data.members[request.auth.uid] != null;
      allow create: if isSignedIn() && request.resource.data.adminUserId == request.auth.uid;
      allow update: if resource != null && (isFamilyAdmin(resource.data) || isFamilyMember(resource.data));
      allow delete: if resource != null && isFamilyAdmin(resource.data);

      /**
       * @description Shared subcollections (Budgets, Goals, Transactions).
       * @path /families/{familyId}/[subcollection]/{id}
       * @allow (read/write) if the user is a member of the family (verified via denormalized map).
       * @principle Authorization Independence through denormalization.
       */
      match /budgets/{budgetId} {
        allow get: if isFamilyMember(resource.data);
        allow list: if isSignedIn() && resource.data.members[request.auth.uid] != null;
        allow create: if isSignedIn() && isFamilyMember(request.resource.data);
        allow update: if resource != null && isFamilyMember(resource.data);
        allow delete: if resource != null && (isFamilyAdmin(resource.data) || isFamilyMember(resource.data));
      }

      match /goals/{goalId} {
        allow get: if isFamilyMember(resource.data);
        allow list: if isSignedIn() && resource.data.members[request.auth.uid] != null;
        allow create: if isSignedIn() && isFamilyMember(request.resource.data);
        allow update: if resource != null && isFamilyMember(resource.data);
        allow delete: if resource != null && (isFamilyAdmin(resource.data) || isFamilyMember(resource.data));
      }

      match /transactions/{transactionId} {
        allow get: if isFamilyMember(resource.data);
        allow list: if isSignedIn() && resource.data.members[request.auth.uid] != null;
        allow create: if isSignedIn() && isFamilyMember(request.resource.data);
        allow update: if resource != null && isFamilyMember(resource.data);
        allow delete: if resource != null && (isFamilyAdmin(resource.data) || isFamilyMember(resource.data));
      }
    }
  }
}