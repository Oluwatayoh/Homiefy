
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role helpers based on Family document
    function getFamily(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId)).data;
    }

    function getRole(familyId) {
      let family = getFamily(familyId);
      return family.members[request.auth.uid];
    }

    function isAdmin(familyId) {
      return isSignedIn() && getRole(familyId) == 'Admin';
    }

    function isCoManager(familyId) {
      return isSignedIn() && getRole(familyId) == 'Co-Manager';
    }

    function isStaff(familyId) {
      let role = getRole(familyId);
      return role == 'Admin' || role == 'Co-Manager';
    }

    function isMember(familyId) {
      let family = getFamily(familyId);
      return family.members.keys().hasAny([request.auth.uid]);
    }

    match /users/{userId} {
      allow get, list, update: if isOwner(userId);
      allow create: if isSignedIn();
    }

    match /families/{familyId} {
      allow get: if isMember(familyId);
      allow create: if isSignedIn();
      allow update: if isAdmin(familyId);
      
      match /budgets/{budgetId} {
        allow read: if isMember(familyId);
        allow write: if isStaff(familyId);
      }
      
      match /transactions/{transactionId} {
        allow read: if isMember(familyId);
        allow create: if isMember(familyId);
        allow update, delete: if isStaff(familyId) || (resource.data.userId == request.auth.uid);
      }

      match /decisions/{decisionId} {
        allow read: if isMember(familyId);
        allow write: if isMember(familyId);
      }

      match /approvals/{approvalId} {
        allow read: if isMember(familyId);
        allow create: if isMember(familyId);
        allow update: if isStaff(familyId);
      }

      match /goals/{goalId} {
        allow read: if isMember(familyId);
        allow write: if isStaff(familyId);
      }
    }
  }
}
