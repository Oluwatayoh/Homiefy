rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HOMIEFY SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * 1. Path-based isolation for User Profiles.
     * 2. Family membership is the gatekeeper for all shared household data.
     * 3. Membership is stored as a map on the Family document: members: { uid: role }
     * 4. Documents in subcollections denormalize this members map for efficient list operations.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper to get the current user's profile data
    function getMyProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    // Checks if the user is a member of the family
    function isFamilyMember(familyId) {
      let family = get(/databases/$(database)/documents/families/$(familyId));
      return isSignedIn() && family != null && family.data.members[request.auth.uid] != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for individual user profiles.
     */
    match /userProfiles/{userId} {
      // Allow reading if owner OR if they share the same familyId (to see names/avatars).
      allow read: if isOwner(userId) || (
        isSignedIn() && 
        resource.data.familyId != null && 
        getMyProfile().familyId == resource.data.familyId
      );
      allow write: if isOwner(userId);
    }

    /**
     * @description Rules for family units and their shared data.
     */
    match /families/{familyId} {
      // Basic family access.
      allow get: if isSignedIn();
      
      // Allow listing families. Filtered queries on membership or invite codes are permitted.
      allow list: if isSignedIn();
      
      // Creation.
      allow create: if isSignedIn();
      
      // Update logic:
      // 1. Existing members can update.
      // 2. New members can join by adding their own UID to the members map if they have the invite code.
      allow update: if isSignedIn() && (
        (resource.data.members[request.auth.uid] != null) || 
        (
          request.resource.data.members[request.auth.uid] != null &&
          request.resource.data.inviteCode == resource.data.inviteCode
        )
      );

      // Only admins can delete the family record.
      allow delete: if isSignedIn() && resource.data.members[request.auth.uid] == 'Admin';

      /**
       * @description Explicit rules for family sub-data.
       * Subcollections check the document's own 'members' map for efficient 'list' operations.
       */
      match /{allSubcollections=**} {
        allow read: if isSignedIn() && (
          (resource != null && resource.data.members[request.auth.uid] != null) ||
          isFamilyMember(familyId)
        );
        
        allow write: if isSignedIn() && 
          isFamilyMember(familyId) && 
          request.resource.data.members[request.auth.uid] != null;
      }
    }
  }
}